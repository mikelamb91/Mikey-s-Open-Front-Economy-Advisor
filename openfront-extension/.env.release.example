# Copy this file to .env.release.local and fill in the values.
# The release script loads .env.release.local automatically.

# Optional if you already ran `gh auth login`.
# Otherwise create a GitHub token with repository contents write access.
GITHUB_TOKEN=

# Optional override. If empty, the script uses the git origin remote.
# Example: marijnbent/openfront-extension
GITHUB_REPOSITORY=

# Chrome Web Store API settings.
# These are required for `npm run release` unless you use `--github-only`.
#
# First-time setup:
# 1. Create or choose a Google Cloud project and enable the Chrome Web Store API.
# 2. Configure an OAuth consent screen.
# 3. Create an OAuth client of type "Web application".
# 4. Add https://developers.google.com/oauthplayground as an authorized redirect URI.
# 5. Use the OAuth Playground with scope:
#    https://www.googleapis.com/auth/chromewebstore
# 6. Copy the client ID, client secret, and refresh token here.

# Chrome Web Store publisher ID from the Developer Dashboard account page.
CWS_PUBLISHER_ID=

# Chrome Web Store item/extension ID.
# If the item does not exist yet, create it manually once in the dashboard first.
CWS_EXTENSION_ID=

# OAuth client credentials from Google Cloud.
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=

# Refresh token from OAuth Playground.
CWS_REFRESH_TOKEN=
